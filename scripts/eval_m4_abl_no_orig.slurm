#!/bin/bash
#SBATCH --partition=alvis
#SBATCH --gpus-per-node=A100fat:1
#SBATCH -A NAISS2026-3-104
#SBATCH --cpus-per-task=8
#SBATCH --time=12:00:00
#SBATCH --job-name=eval_abl_no_orig
#SBATCH --output=logs/eval_m4_abl_no_orig_%j.out
#SBATCH --error=logs/eval_m4_abl_no_orig_%j.err

set -euo pipefail
export PYTHONHASHSEED=42

PROJECT=/mimer/NOBACKUP/groups/llm-readability/EditBoundaryDetection
cd "$PROJECT"
module load Python/3.11.3-GCCcore-12.3.0
source gpu_env/bin/activate

echo "Job started: $(date)"
echo "Node: $(hostname)"
echo "GPU: $(nvidia-smi --query-gpu=name --format=csv,noheader)"

# E5 ablation: M4 trained without ORIG entity (no orig_hunk / req_orig pairs).
# Evaluate with gamma=0 (matched score: no ORIG term) for fairest comparison.
python evaluate.py \
    --checkpoint checkpoints/m4_abl_no_orig/best.pt \
    --instances  data/processed/instances_full.jsonl \
    --tier3      data/cache/tier3_hunks.jsonl \
    --exp        all \
    --score-alpha 1.0 \
    --score-beta  0.5 \
    --score-gamma 0.0

echo "Done: $(date)"
