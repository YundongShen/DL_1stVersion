#!/bin/bash
#SBATCH --partition=alvis
#SBATCH --gpus-per-node=A100fat:1
#SBATCH -A NAISS2026-3-104
#SBATCH --cpus-per-task=8
#SBATCH --time=7-00:00:00
#SBATCH --job-name=abl_no_req
#SBATCH --output=logs/ablate_no_req_%j.out
#SBATCH --error=logs/ablate_no_req_%j.err

set -euo pipefail
export PYTHONHASHSEED=42

PROJECT=/mimer/NOBACKUP/groups/llm-readability/EditBoundaryDetection
cd "$PROJECT"
module load Python/3.11.3-GCCcore-12.3.0
source gpu_env/bin/activate

echo "Job started: $(date)"
echo "Node: $(hostname)"
echo "GPU: $(nvidia-smi --query-gpu=name --format=csv,noheader)"

# Supplementary ablation on M4: remove REQ entity (orig_hunk only)
python train.py \
    --instances data/processed/instances_full.jsonl \
    --encoder   microsoft/unixcoder-base \
    --epochs    10 \
    --checkpoint-dir checkpoints/m4_abl_no_req \
    --pair-types orig_hunk \
    --tier3     data/cache/tier3_hunks.jsonl \
    --same-repo \
    --tier-aware-loss

echo "Done: $(date)"
